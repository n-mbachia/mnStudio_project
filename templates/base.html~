{% load static %}
<!DOCTYPE html>
<html lang="en" class="h-full bg-stone-50">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}MN Studio{% endblock %} — Bespoke Hardwood Furniture, Nairobi</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght=0,400;0,600;1,400&family=Jost:wght=300;400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { serif: ['Cormorant Garamond', 'Georgia', 'serif'], sans: ['Jost', 'system-ui', 'sans-serif'] },
          colors: {
            mahogany: { 50:'#fdf6f0', 100:'#fae8d8', 200:'#f4cdb0', 300:'#ebaa80', 400:'#e07f4a', 500:'#d4622a', 600:'#b84f20', 700:'#963d1b', 800:'#7a321b', 900:'#652c1b' },
            forest:   { 50:'#f2f7f0', 100:'#e0eddc', 200:'#c2dabb', 300:'#96be8e', 400:'#689f5f', 500:'#4a8241', 600:'#3a6833', 700:'#2f5429', 800:'#284624', 900:'#22391f' },
            charcoal: { 50:'#f6f6f6', 100:'#e7e7e7', 200:'#d1d1d1', 300:'#b0b0b0', 400:'#888888', 500:'#6d6d6d', 600:'#5d5d5d', 700:'#4f4f4f', 800:'#454545', 900:'#1a1a1a' }
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Jost', system-ui, sans-serif; }
    h1,h2,h3,.font-serif { font-family: 'Cormorant Garamond', Georgia, serif; }
    /* Hardened link definitions with absolute fallbacks */
    .sidebar-link { @apply flex items-center gap-3 px-4 py-2.5 rounded-lg text-stone-300/90 hover:bg-white/[0.06] hover:text-white transition-all text-sm font-medium; }
    .sidebar-link.active { @apply bg-mahogany-700 text-white shadow-sm shadow-mahogany-950/40 font-semibold; }
    .card { @apply bg-white rounded-xl shadow-sm border border-stone-100 p-6; }
    .btn-primary { @apply inline-flex items-center gap-2 bg-mahogany-700 hover:bg-mahogany-800 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors; }
    .btn-secondary { @apply inline-flex items-center gap-2 bg-white hover:bg-stone-50 text-stone-700 text-sm font-medium px-4 py-2.5 rounded-lg border border-stone-200 transition-colors; }
    .btn-ghost { @apply inline-flex items-center gap-2 text-stone-500 hover:text-stone-800 text-sm font-medium px-3 py-2 rounded-lg hover:bg-stone-100 transition-colors; }
    .badge { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium; }
    .input { @apply w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-mahogany-500 focus:border-transparent; }
    .label { @apply block text-xs font-semibold text-stone-500 uppercase tracking-wider mb-1; }
    .table-header { @apply text-left text-xs font-semibold text-stone-400 uppercase tracking-wider py-3 px-4; }
    .table-cell { @apply py-3 px-4 text-sm text-stone-700 border-t border-stone-50; }
  </style>
  {% block extra_head %}{% endblock %}
</head>
<body class="h-full">
{% block body %}

{% if user.is_authenticated %}
<!-- ADMIN SHELL -->
<div class="flex h-screen overflow-hidden" x-data="{ sidebarOpen: false }">

  <!-- Sidebar Container -->
  <aside class="w-64 bg-charcoal-200 flex flex-col shrink-0 hidden lg:flex border-r border-white/5">
    <div class="p-6 border-b border-white/5 bg-charcoal-950/20">
      <h1 class="font-serif text-2xl text-white tracking-wide">MN Studio</h1>
      <p class="text-mahogany-500 text-xs mt-0.5 tracking-wider font-mono uppercase">Business OS</p>
    </div>
    
    <nav class="flex-1 p-4 space-y-1.5 overflow-y-auto custom-scrollbar">
      <!-- Operations Group -->
      <p class="text-[10px] font-bold text-mahogany-500 uppercase tracking-widest px-4 pt-2 pb-1">Operations</p>
      <a href="{% url 'dashboard' %}" class="sidebar-link {% if request.resolver_match.url_name == 'dashboard' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span>Dashboard</span>
      </a>
      <a href="{% url 'production:jobcard_list' %}" class="sidebar-link {% if request.resolver_match.namespace == 'production' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <span>Job Cards</span>
      </a>
      
      <!-- CRM Group -->
      <p class="text-[10px] font-bold text-mahogany-500 uppercase tracking-widest px-4 pt-4 pb-1">CRM</p>
      <a href="{% url 'crm:client_list' %}" class="sidebar-link {% if request.resolver_match.url_name == 'client_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span>Clients</span>
      </a>
      <a href="{% url 'crm:pipeline' %}" class="sidebar-link {% if request.resolver_match.url_name == 'pipeline' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        <span>Pipeline</span>
      </a>
      
      <!-- Finance Group -->
      <p class="text-[10px] font-bold text-mahogany-500 uppercase tracking-widest px-4 pt-4 pb-1">Finance</p>
      <a href="{% url 'ledger:quote_list' %}" class="sidebar-link {% if request.resolver_match.url_name == 'quote_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span>Quotes</span>
      </a>
      <a href="{% url 'ledger:invoice_list' %}" class="sidebar-link {% if request.resolver_match.url_name == 'invoice_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
        <span>Invoices</span>
      </a>
      <a href="{% url 'ledger:compliance_dashboard' %}" class="sidebar-link {% if request.resolver_match.url_name == 'compliance_dashboard' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        <span>Compliance</span>
      </a>
      
      <!-- Supply Chain Group -->
      <p class="text-[10px] font-bold text-mahogany-500 uppercase tracking-widest px-4 pt-4 pb-1">Supply Chain</p>
      <a href="{% url 'partners:supplier_list' %}" class="sidebar-link {% if request.resolver_match.url_name == 'supplier_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <span>Suppliers</span>
      </a>
      <a href="{% url 'partners:po_list' %}" class="sidebar-link {% if request.resolver_match.url_name == 'po_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        <span>Purchase Orders</span>
      </a>
      <a href="{% url 'partners:artisan_list' %}" class="sidebar-link {% if request.resolver_match.url_name == 'artisan_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span>Artisans</span>
      </a>
      
      <!-- Storefront Group -->
      <p class="text-[10px] font-bold text-mahogany-500 uppercase tracking-widest px-4 pt-4 pb-1">Storefront</p>
      <a href="{% url 'storefront:product_list' %}" class="sidebar-link {% if request.resolver_match.namespace == 'storefront' and request.resolver_match.url_name == 'product_list' %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        <span>Catalogue</span>
      </a>
      <a href="{% url 'storefront:auction_list' %}" class="sidebar-link {% if request.resolver_match.namespace == 'storefront' and 'auction' in request.resolver_match.url_name %}active{% endif %}">
        <svg class="w-4 h-4 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>Live Auctions</span>
      </a>
    </nav>
    
    <div class="p-4 border-t border-white/5 bg-charcoal-950/10">
      <a href="{% url 'logout' %}" class="sidebar-link text-stone-400 hover:text-red-400 hover:bg-red-950/20">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        <span>Sign Out</span>
      </a>
    </div>
  </aside>

  <!-- Main content -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- Top bar -->
    <header class="bg-white border-b border-stone-100 px-6 py-4 flex items-center justify-between shrink-0">
      <div>
        <h2 class="font-serif text-xl text-charcoal-900">{% block page_title %}Dashboard{% endblock %}</h2>
        {% block breadcrumb %}<p class="text-xs text-stone-400 mt-0.5">MN Studio Business OS</p>{% endblock %}
      </div>
      <div class="flex items-center gap-3">
        {% block header_actions %}{% endblock %}
        <span class="text-sm text-stone-500 font-medium">{{ user.get_full_name|default:user.username }}</span>
      </div>
    </header>

    <!-- Messages -->
    {% if messages %}
    <div class="px-6 pt-4 space-y-2">
      {% for m in messages %}
      <div class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm
        {% if m.tags == 'success' %}bg-forest-50 text-forest-800 border border-forest-200
        {% elif m.tags == 'error' %}bg-red-50 text-red-800 border border-red-200
        {% else %}bg-blue-50 text-blue-800 border border-blue-200{% endif %}">
        {{ m }}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <!-- Page content -->
    <main class="flex-1 overflow-y-auto p-6">
      {% block content %}{% endblock %}
    </main>
  </div>
</div>

{% else %}
<!-- PUBLIC SHELL -->
<div class="min-h-screen">
  {% block public_content %}{% endblock %}
</div>
{% endif %}

{% endblock body %}
{% block extra_scripts %}{% endblock %}
</body>
</html>

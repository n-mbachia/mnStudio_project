<!-- templates/storefront/product_detail.html -->

{% extends "base.html" %}
{% block title %}{{ product.name }} — Registry Design — MN Studio{% endblock %}
{% block public_content %}

<div class="min-h-screen bg-stone-50 text-charcoal-900 py-16 px-6 sm:px-8 relative overflow-hidden">
  <!-- Subtle minimalist design line accents -->
  <div class="absolute inset-y-0 left-1/4 w-px bg-stone-200/40 pointer-events-none hidden lg:block"></div>
  <div class="absolute inset-y-0 left-3/4 w-px bg-stone-200/40 pointer-events-none hidden lg:block"></div>

  <div class="max-w-5xl mx-auto relative z-10">
    <!-- Back to Collection Navigation -->
    <a href="{% url 'storefront:product_list' %}" class="inline-flex items-center gap-1.5 text-stone-400 text-xs font-medium uppercase tracking-wider hover:text-stone-800 transition-colors group">
      <span class="transform group-hover:-translate-x-1 transition-transform">&larr;</span> Back to Registry Collection
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 mt-8 items-start">
      
      <!-- Left Column: Media Gallery Showcase (6 Columns) -->
      <div class="lg:col-span-6 space-y-4">
        <div class="bg-white rounded-2xl aspect-[4/3] sm:aspect-[16/11] flex items-center justify-center overflow-hidden border border-stone-200/60 shadow-sm relative group">
          {% if media_items %}
            <!-- Primary Active Media View -->
            <div id="featured-viewport" class="w-full h-full">
              {% with media_items|first as default_media %}
                {% if default_media.media_type == 'VIDEO' %}
                  <video src="{{ default_media.media_url }}" class="w-full h-full object-cover object-center" autoplay muted loop playsinline></video>
                {% else %}
                  <img src="{{ default_media.media_url }}" alt="{{ product.name }}" class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-102">
                {% endif %}
              {% endwith %}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/5 to-transparent mix-blend-multiply pointer-events-none"></div>
          {% else %}
            <!-- Clean Architectural Fallback Visual Frame -->
            <div class="absolute inset-0 bg-gradient-to-br from-stone-50 to-stone-100 flex flex-col items-center justify-center text-center p-6">
              <div class="w-12 h-12 border border-stone-200 rounded-full flex items-center justify-center text-stone-400 font-mono text-xs mb-2">3D</div>
              <span class="text-[10px] uppercase tracking-widest text-stone-400 font-mono">Media Asset Render Pending</span>
            </div>
          {% endif %}
        </div>

        <!-- Secondary Carousel Thumbnail Strip -->
        {% if media_items|length > 1 %}
        <div class="flex items-center gap-3 overflow-x-auto pb-1 custom-scrollbar">
          {% for item in media_items %}
            <button class="w-20 h-16 rounded-lg overflow-hidden border {% if forloop.first %}border-mahogany-600{% else %}border-stone-200/80{% endif %} bg-white shadow-sm shrink-0 transition-all hover:border-mahogany-500"
                    onclick="switchShowcase('{{ item.media_url }}', '{{ item.media_type }}', this)">
              {% if item.media_type == 'VIDEO' %}
                <div class="w-full h-full relative bg-stone-900 flex items-center justify-center">
                  <img src="{{ item.thumbnail_url|default:item.media_url }}" class="w-full h-full object-cover opacity-60">
                  <span class="absolute text-[10px] bg-black/40 text-white px-1 rounded font-mono scale-90">MOV</span>
                </div>
              {% else %}
                <img src="{{ item.media_url }}" alt="Configuration view" class="w-full h-full object-cover">
              {% endif %}
            </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- Right Column: Specification Architecture Ledger (6 Columns) -->
      <div class="lg:col-span-6 space-y-8">
        <div>
          <!-- Category Tracker -->
          <span class="inline-flex text-[10px] font-bold uppercase tracking-[0.2em] text-mahogany-600 mb-2 block">
            {{ product.get_category_display }}
          </span>
          
          <!-- Master Designation Title -->
          <h1 class="font-serif text-4xl sm:text-5xl text-charcoal-900 tracking-tight leading-tight mb-4">
            {{ product.name }}
          </h1>
          
          <!-- Production Description Details -->
          <p class="text-stone-500 text-sm font-light leading-relaxed">
            {{ product.description }}
          </p>
        </div>

        <!-- Architectural Blueprint Specifications List -->
        <div class="bg-white rounded-2xl border border-stone-200/60 p-6 shadow-sm">
          <h3 class="text-[10px] font-bold uppercase tracking-widest text-stone-400 mb-4 pb-2 border-b border-stone-100">Commission Blueprint Matrix</h3>
          
          <dl class="space-y-3.5 text-xs">
            <div class="flex justify-between items-center py-1">
              <dt class="text-stone-400 uppercase tracking-wider font-medium text-[11px]">Primary Wood Stock</dt>
              <dd class="font-serif text-stone-800 italic text-sm">{{ product.primary_species|default:"Custom Selection (Mvule / Mahogany)" }}</dd>
            </div>
            <div class="flex justify-between items-center py-1 border-t border-stone-100/60">
              <dt class="text-stone-400 uppercase tracking-wider font-medium text-[11px]">Initial Configuration Base</dt>
              <dd class="font-semibold text-charcoal-900 font-mono text-sm">KES {{ product.starting_price|floatformat:0 }}</dd>
            </div>
            <div class="flex justify-between items-center py-1 border-t border-stone-100/60">
              <dt class="text-stone-400 uppercase tracking-wider font-medium text-[11px]">Standard Production Cycle</dt>
              <dd class="font-medium text-stone-700 font-mono">{{ product.lead_time_days }} Days</dd>
            </div>
          </dl>
        </div>

        <!-- Direct Engagement Action Interfaces -->
        <div class="flex flex-col sm:flex-row items-stretch gap-3.5">
          <!-- Main Whatsapp Commission Route -->
          <a href="{{ product.whatsapp_url }}" target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-2.5 bg-[#128C7E] hover:bg-[#0b665c] text-white px-6 py-4 rounded-xl text-xs uppercase tracking-widest font-semibold transition-colors shadow-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enquire via WhatsApp
          </a>

          <!-- Secondary Allocation Request Route -->
          <a href="{% url 'storefront:waitlist' %}" class="inline-flex items-center justify-center border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 hover:text-stone-900 px-6 py-4 rounded-xl text-xs uppercase tracking-widest font-semibold transition-colors">
            Queue Waitlist Allocation
          </a>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Dynamic Showcase View Switcher -->
<script>
function switchShowcase(url, type, element) {
    const frame = document.getElementById('featured-viewport');
    
    // Clear borders from all sibling buttons
    if (element && element.parentElement) {
        Array.from(element.parentElement.children).forEach(btn => {
            btn.classList.remove('border-mahogany-600');
            btn.classList.add('border-stone-200/80');
        });
        element.classList.add('border-mahogany-600');
        element.classList.remove('border-stone-200/80');
    }

    if(type === 'VIDEO') {
        frame.innerHTML = `<video src="${url}" class="w-full h-full object-cover object-center" controls autoplay muted loop playsinline></video>`;
    } else {
        frame.innerHTML = `<img src="${url}" class="w-full h-full object-cover object-center transition-transform duration-500 hover:scale-102">`;
    }
}
</script>

{% endblock %}

<!-- ./templates/storefront/waitlist_success.html -->

{% extends "base.html" %}
{% block title %}Application Received — MN Studio{% endblock %}

{% block public_content %}
<div class="min-h-screen bg-charcoal-950 flex items-center justify-center px-4 sm:px-6 lg:px-8 relative overflow-hidden pt-24">
  <!-- Background accents -->
  <div class="absolute inset-y-0 left-1/3 w-px bg-white/[0.02] pointer-events-none hidden md:block"></div>
  <div class="absolute inset-y-0 left-2/3 w-px bg-white/[0.02] pointer-events-none hidden md:block"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(184,111,86,0.05),transparent_60%)]"></div>

  <div class="text-center max-w-lg relative z-10 py-16 reveal">
    <!-- Success Icon -->
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-mahogany-900/30 border border-mahogany-500/20 mb-8 animate-scale-in">
      <div class="w-14 h-14 rounded-full bg-mahogany-700 flex items-center justify-center">
        <i data-lucide="check" class="w-7 h-7 text-white"></i>
      </div>
    </div>

    <!-- Typography -->
    <h1 class="font-serif text-4xl sm:text-5xl text-white tracking-tight mb-4 animate-fade-in-up animate-delay-100">
      Your request is <span class="italic font-normal text-mahogany-400">registered</span>.
    </h1>
    
    <p class="text-charcoal-400 text-base sm:text-lg font-light leading-relaxed mb-10 max-w-md mx-auto animate-fade-in-up animate-delay-200">
      Thank you for sharing your design vision with us. We evaluate incoming capacity cycles weekly and will initiate a formal consultation when your project timeline aligns.
    </p>
    
    <!-- Actions -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up animate-delay-300">
      <a href="{% url 'storefront:product_list' %}" class="group inline-flex items-center justify-center gap-2 bg-mahogany-700 hover:bg-mahogany-600 text-white px-8 py-3.5 rounded-xl font-medium text-sm transition-all shadow-lg hover:shadow-xl">
        Browse Current Catalog
        <i data-lucide="arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1"></i>
      </a>
      <a href="{% url 'home' %}" class="inline-flex items-center justify-center gap-2 border border-black/10 text-charcoal-400 hover:text-mahogany-500 hover:bg-white/5 px-6 py-3.5 rounded-xl text-sm font-medium transition-all">
        <i data-lucide="home" class="w-4 h-4"></i>
        Return Home
      </a>
    </div>
    
    <!-- Timeline indicator -->
    <div class="mt-12 pt-8 border-t border-white/5 animate-fade-in-up animate-delay-400">
      <div class="flex items-center justify-center gap-8 text-xs text-charcoal-500">
        <div class="flex items-center gap-2">
          <i data-lucide="clock" class="w-3.5 h-3.5 text-mahogany-500"></i>
          <span>Response within 1-3 business days</span>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
